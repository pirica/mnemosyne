      "id": "file:mnemosyne/core/beam.py",
      "type": "file",
      "name": "beam.py",
      "filePath": "mnemosyne/core/beam.py",
      "summary": "Bilevel Episodic-Associative Memory (BEAM) architecture implementing Mnemosyne's core memory subsystem with working memory, episodic memory, scratchpad, vector search via sqlite-vec, FTS5 full-text retrieval, and hybrid ranking. Contains the main BeamMemory class with 65 methods for remember, recall, sleep, consolidation, polyphonic recall, fact extraction, and memory diagnostics.",
      "tags": [
        "memory-system",
        "vector-search",
        "fts5",
        "sqlite",
        "hybrid-retrieval",
        "tested"
      ],
      "complexity": "complex",
      "languageNotes": "Python module using sqlite-vec for native vector search, FTS5 for full-text, and a 50/30/20 hybrid ranking formula."
    },
