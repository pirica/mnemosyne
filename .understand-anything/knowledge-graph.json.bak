    {
      "id": "concept:5-tier query cache",
      "type": "concept",
      "label": "5-Tier Query Cache Architecture",
      "domain": "caching",
      "description": "Tier 1: exact normalized match (O(1) hash map). Tier 2: cosine >= 0.88 embedding match. Tier 3: cosine >= 0.78 + Jaccard >= 0.15 composite. Tier 4: synonym-expanded match. Tier 5: full search compute-and-cache.",
      "complexity": "moderate",
      "tags": [
        "untagged"
      ],
      "summary": "concept:5-tier query cache"
    },
