      "id": "concept:query_cache_invalidation",
      "type": "concept",
      "label": "Cache Invalidation on remember()",
      "domain": "caching",
      "description": "Cache version counter incremented on every remember() call. All tiers cleared. SQLite entries deleted.",
      "complexity": "moderate",
      "tags": [
        "untagged"
      ],
      "summary": "concept:query_cache_invalidation"
    },
